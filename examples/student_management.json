{
  "project": {
    "groupId": "com.example",
    "artifactId": "student-management",
    "name": "student-management",
    "basePackage": "com.example.student",
    "bootVersion": "2.7.18",
    "javaVersion": 8
  },
  "datasource": {
    "url": "jdbc:mysql://127.0.0.1:3306/student_management?useSSL=false&serverTimezone=UTC&characterEncoding=UTF-8",
    "username": "root",
    "password": "123456",
    "driverClassName": "com.mysql.cj.jdbc.Driver"
  },
  "tables": [
    {
      "name": "students",
      "comment": "student table",
      "entityName": "Student",
      "primaryKey": "id",
      "queryableFields": [
        {
          "name": "student_name",
          "operator": "LIKE"
        },
        {
          "name": "student_no",
          "operator": "EQ"
        }
      ],
      "fields": [
        {
          "name": "id",
          "type": "bigint",
          "nullable": false,
          "comment": "primary key",
          "idType": "AUTO"
        },
        {
          "name": "student_no",
          "type": "varchar(32)",
          "nullable": false,
          "comment": "student number",
          "unique": true
        },
        {
          "name": "student_name",
          "type": "varchar(64)",
          "nullable": false,
          "comment": "student name"
        },
        {
          "name": "gender",
          "type": "varchar(16)",
          "nullable": true,
          "comment": "gender"
        },
        {
          "name": "age",
          "type": "int",
          "nullable": true,
          "comment": "age"
        },
        {
          "name": "created_at",
          "type": "datetime",
          "nullable": false,
          "comment": "created time",
          "autoFill": "INSERT"
        },
        {
          "name": "updated_at",
          "type": "datetime",
          "nullable": false,
          "comment": "updated time",
          "autoFill": "INSERT_UPDATE"
        }
      ]
    }
  ],
  "relations": [],
  "global": {
    "apiPrefix": "/api",
    "author": "codegen",
    "dateTimeFormat": "yyyy-MM-dd HH:mm:ss",
    "enableSwagger": false
  }
}
