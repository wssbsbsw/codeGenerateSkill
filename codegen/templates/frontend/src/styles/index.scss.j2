$bg: #f3f6f9;
$panel: #ffffff;
$ink: #1f2a37;
$muted: #667085;
$line: #d9e2ec;
$primary: #2762ff;
$primary-soft: #e8efff;
$sidebar-start: #0f172a;
$sidebar-end: #1e293b;

* {
  box-sizing: border-box;
}

html,
body,
#app {
  margin: 0;
  min-height: 100%;
  background: radial-gradient(circle at top left, #f9fbff 0%, $bg 48%, #eef2f6 100%);
  color: $ink;
  font-family: "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
}

a {
  color: inherit;
  text-decoration: none;
}

.layout-shell {
  display: flex;
  min-height: 100vh;
}

.layout-sidebar {
  width: 250px;
  padding: 24px 18px;
  background: linear-gradient(180deg, $sidebar-start 0%, $sidebar-end 100%);
  color: #fff;
  box-shadow: 20px 0 45px rgba(15, 23, 42, 0.14);
}

.brand-block {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 24px;
  padding: 12px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.06);
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  height: 42px;
  border-radius: 14px;
  background: linear-gradient(135deg, #7aa2ff 0%, #3b82f6 100%);
  font-weight: 700;
}

.brand-title,
.layout-title {
  margin: 0;
  font-weight: 700;
}

.brand-subtitle,
.layout-caption {
  margin: 6px 0 0;
  color: $muted;
  font-size: 13px;
}

.sidebar-menu {
  border-right: none;
}

.sidebar-menu .el-menu-item,
.sidebar-menu .el-submenu__title {
  border-radius: 12px;
}

.sidebar-menu .el-menu-item.is-active {
  background: rgba(255, 255, 255, 0.12) !important;
}

.layout-main {
  flex: 1;
  min-width: 0;
}

.layout-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28px 32px 8px;
}

.layout-chip {
  padding: 10px 14px;
  border: 1px solid $line;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.72);
  color: $muted;
  font-size: 13px;
}

.layout-content {
  padding: 0 32px 32px;
}

.page-shell {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.page-hero,
.dashboard-hero {
  padding: 24px 28px;
  border: 1px solid rgba(39, 98, 255, 0.08);
  border-radius: 24px;
  background: linear-gradient(135deg, rgba(39, 98, 255, 0.08) 0%, rgba(255, 255, 255, 0.92) 55%, rgba(255, 255, 255, 0.98) 100%);
  box-shadow: 0 18px 35px rgba(15, 23, 42, 0.05);
}

.page-hero h3,
.dashboard-hero h2 {
  margin: 0 0 8px;
}

.page-hero p,
.dashboard-hero p {
  margin: 0;
  color: $muted;
}

.page-card,
.dashboard-card,
.dashboard-links {
  border: 1px solid rgba(15, 23, 42, 0.06);
  border-radius: 22px;
  background: $panel;
  box-shadow: 0 16px 35px rgba(15, 23, 42, 0.05);
}

.query-form .el-form-item {
  margin-right: 14px;
  margin-bottom: 14px;
}

.toolbar-row,
.pagination-row,
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.toolbar-row {
  margin-bottom: 18px;
}

.toolbar-row h3,
.card-header h3 {
  margin: 0;
}

.toolbar-row p,
.card-header p {
  margin: 6px 0 0;
  color: $muted;
}

.pagination-row {
  justify-content: flex-end;
  margin-top: 18px;
}

.dashboard-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 16px;
}

.dashboard-card {
  padding: 22px;
}

.dashboard-value {
  margin: 18px 0 6px;
  font-size: 36px;
  font-weight: 700;
}

.dashboard-link-list {
  display: grid;
  gap: 10px;
}

.dashboard-link-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px;
  border: 1px solid $line;
  border-radius: 16px;
  background: linear-gradient(180deg, #ffffff 0%, #fbfcfe 100%);
  transition: transform 0.18s ease, box-shadow 0.18s ease;
}

.dashboard-link-item:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 22px rgba(15, 23, 42, 0.08);
}

.detail-value {
  color: $muted;
}

@media (max-width: 960px) {
  .layout-shell {
    flex-direction: column;
  }

  .layout-sidebar {
    width: 100%;
  }

  .layout-header,
  .layout-content {
    padding-left: 16px;
    padding-right: 16px;
  }
}
