import axios from "axios"
import { Message } from "element-ui"

const service = axios.create({
  baseURL: process.env.VUE_APP_BASE_API || "{{ project.api_prefix }}",
  timeout: 15000
})

service.interceptors.response.use(
  (response) => {
    const payload = response.data
    if (!payload) {
      Message.error("Empty response received")
      return Promise.reject(new Error("Empty response received"))
    }
    if (response.data.code !== 0) {
      Message.error(payload.message || "Request failed")
      return Promise.reject(new Error(payload.message || "Request failed"))
    }
    return payload.data
  },
  (error) => {
    const responseMessage = error.response && error.response.data && error.response.data.message
    Message.error(responseMessage || error.message || "Network request failed")
    return Promise.reject(error)
  }
)

export default service
