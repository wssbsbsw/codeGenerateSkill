package {{ package }}.service.impl;

import {{ package }}.dto.DictionaryOption;
import {{ package }}.entity.SysDictItem;
import {{ package }}.entity.SysDictType;
import {{ package }}.mapper.SysDictItemMapper;
import {{ package }}.mapper.SysDictTypeMapper;
import {{ package }}.service.DictionaryService;
import com.baomidou.mybatisplus.core.conditions.query.QueryWrapper;
import org.springframework.stereotype.Service;
import org.springframework.util.StringUtils;

import java.util.ArrayList;
import java.util.List;

@Service
public class DictionaryServiceImpl implements DictionaryService {

    private final SysDictTypeMapper sysDictTypeMapper;
    private final SysDictItemMapper sysDictItemMapper;

    public DictionaryServiceImpl(
            SysDictTypeMapper sysDictTypeMapper,
            SysDictItemMapper sysDictItemMapper
    ) {
        this.sysDictTypeMapper = sysDictTypeMapper;
        this.sysDictItemMapper = sysDictItemMapper;
    }

    @Override
    public List<DictionaryOption> listEnabledOptions(String dictKey) {
        SysDictType dictType = loadDictType(dictKey);
        List<SysDictItem> items = loadEnabledItems(dictType.getId());
        List<DictionaryOption> options = new ArrayList<>();
        for (SysDictItem item : items) {
            options.add(new DictionaryOption(
                    item.getItemLabel(),
                    parseValue(item.getItemValue(), dictType.getValueType())
            ));
        }
        return options;
    }

    @Override
    public String resolveLabel(String dictKey, Object value) {
        if (value == null) {
            return null;
        }
        SysDictType dictType = loadDictType(dictKey);
        String storedValue = toStoredValue(value, dictType.getValueType());
        for (SysDictItem item : loadEnabledItems(dictType.getId())) {
            if (storedValue.equals(item.getItemValue())) {
                return item.getItemLabel();
            }
        }
        return String.valueOf(value);
    }

    @Override
    public Object resolveValue(String dictKey, String rawInput) {
        if (!StringUtils.hasText(rawInput)) {
            return null;
        }
        SysDictType dictType = loadDictType(dictKey);
        List<SysDictItem> items = loadEnabledItems(dictType.getId());
        String trimmedInput = rawInput.trim();
        String normalizedValue = null;
        try {
            normalizedValue = toStoredValue(
                    parseValue(trimmedInput, dictType.getValueType()),
                    dictType.getValueType()
            );
        } catch (IllegalArgumentException ignored) {
            normalizedValue = null;
        }
        for (SysDictItem item : items) {
            if (item.getItemLabel().equals(trimmedInput)) {
                return parseValue(item.getItemValue(), dictType.getValueType());
            }
            if (normalizedValue != null && normalizedValue.equals(item.getItemValue())) {
                return parseValue(item.getItemValue(), dictType.getValueType());
            }
        }
        throw new IllegalArgumentException(
                "Invalid dictionary value for '" + dictKey + "': " + rawInput
        );
    }

    private SysDictType loadDictType(String dictKey) {
        SysDictType dictType = sysDictTypeMapper.selectOne(
                new QueryWrapper<SysDictType>().eq("dict_key", dictKey)
        );
        if (dictType == null) {
            throw new IllegalArgumentException("Dictionary not found: " + dictKey);
        }
        return dictType;
    }

    private List<SysDictItem> loadEnabledItems(Long dictTypeId) {
        return sysDictItemMapper.selectList(
                new QueryWrapper<SysDictItem>()
                        .eq("dict_type_id", dictTypeId)
                        .eq("enabled", 1)
                        .orderByAsc("sort", "id")
        );
    }

    private Object parseValue(String value, String valueType) {
        if ("integer".equals(valueType)) {
            return Integer.valueOf(value);
        }
        if ("long".equals(valueType)) {
            return Long.valueOf(value);
        }
        if ("boolean".equals(valueType)) {
            if ("true".equalsIgnoreCase(value) || "1".equals(value)) {
                return true;
            }
            if ("false".equalsIgnoreCase(value) || "0".equals(value)) {
                return false;
            }
            throw new IllegalArgumentException("Invalid boolean dictionary value: " + value);
        }
        return value;
    }

    private String toStoredValue(Object value, String valueType) {
        if ("boolean".equals(valueType)) {
            return Boolean.TRUE.equals(value) ? "true" : "false";
        }
        return String.valueOf(value);
    }
}
